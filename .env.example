# ─────────────────────────────────────────────────────────────────────────────
# F&B Smart Ledger — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Project Settings → API

# Your Supabase project URL (safe to expose — used on client and server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key (safe to expose — RLS protects your data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — SERVER ONLY, never expose to the browser.
# Used only in trusted server contexts (e.g. scheduled jobs, admin scripts).
# If you are not using any service-role server routes, you can leave this blank.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used for OAuth redirects and absolute URL generation.
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── AI / Invoice Extraction ──────────────────────────────────────────────────
# Optional. If neither key is set, the app falls back to mock extraction
# automatically — the full invoice flow still works with sample data.
#
# Option A — OpenAI GPT-4o Vision (recommended)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Option B — Anthropic Claude Vision (alternative, not enabled by default)
# Uncomment the line in lib/ai/invoice-extractor.ts to activate.
# ANTHROPIC_API_KEY=sk-ant-...
